#SQL code used for analysis:

SELECT
    B.name AS business_name,
    AVG(B.stars) AS average_rating,
    MAX(H.hours) AS hours,
    B.review_count,
    B.postal_code,
    B.neighborhood,
    SUM(CASE WHEN B.stars BETWEEN 2 AND 3 THEN B.review_count ELSE 0 END) AS ReviewCount_2to3_stars,
    SUM(CASE WHEN B.stars BETWEEN 4 AND 5 THEN B.review_count ELSE 0 END) AS ReviewCount_4to5_stars
FROM
    category C
    INNER JOIN business B ON C.business_id = B.id
    INNER JOIN hours H ON B.id = H.business_id
WHERE
    B.city = 'Toronto'
    AND C.category = 'Restaurants'
GROUP BY
    B.name, B.review_count, B.postal_code, B.neighborhood
ORDER BY
    average_rating ASC;



